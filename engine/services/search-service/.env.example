# Service
NODE_ENV=development
PORT=3001

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
CACHE_TTL_SECONDS=600

# Ranking Service
RANKING_SERVICE_URL=http://localhost:4000
RANKING_TIMEOUT_MS=10000

# Kafka Analytics (optional)
KAFKA_BROKERS=localhost:9092
KAFKA_CLIENT_ID=search-service
KAFKA_ANALYTICS_TOPIC=search-analytics
KAFKA_RETRIES=3
KAFKA_INITIAL_RETRY_TIME=300
KAFKA_SEND_TIMEOUT_MS=5000

# General
LOG_LEVEL=info
CORS_ORIGIN=*
